DEBUG_REQUESTS=false

AGENT_NAME=My Agent

ANTHROPIC_API_KEY=...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# /path/to/target/project + .temp/plan.md
SYSTEM_PROMPT=You are an autonomous agent. Follow the plan in .temp/plan.md

PROJECT_PATH=/path/to/target/project
MODEL=claude-opus-4-6
MAX_TOKENS=256000
SHOW_THINKING=true
EFFORT=high
DELAY=2

TG_BOT_TOKEN=
TG_USER_ID=

DATABASE_URL=
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
# DATABASE_URL=mysql://user:pass@localhost:3306/mydb
# DATABASE_URL=sqlite:///data.db
# DATABASE_URL=mongodb://user:pass@localhost:27017/mydb
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/mydb

REFERENCE_SITES=[]
# REFERENCE_SITES=["https://example1.com", "https://example2.com", "https://example3.com"]

MCP_SERVERS_CONFIG=./mcp_servers.json
SKILLS_DIR=./skills

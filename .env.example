AGENT_NAME=My Agent

# LLM provider: "anthropic" or "openai"
LLM_API_PROVIDER=anthropic
# Image generation provider: "openai", "gemini" or "" (disabled)
# Leave empty to disable image generation
IMAGE_API_PROVIDER=

# Default Models
MODEL=claude-opus-4-6
IMAGE_MODEL=gemini-2.5-flash-image

# Gemini API (for image generation when IMAGE_API_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Anthropic API
ANTHROPIC_API_KEY=...
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL=claude-opus-4-6

# OpenAI API
OPENAI_API_KEY=...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.3-codex
OPENAI_IMAGE_MODEL=gpt-5-image

# /path/to/target/project + .temp/plan.md
SYSTEM_PROMPT=You are an autonomous agent. Follow the plan in .temp/plan.md

PROJECT_PATH=/path/to/target/project

# Context window — model's max context size in tokens
# 0 = auto-detect from model name (recommended for Claude/GPT)
# Set manually for proxied/custom models: 12000, 32000, 128000, etc.
# Small values (< 32K) activate compact prompt mode 
CONTEXT_WINDOW=0
MAX_TOKENS=128000
SHOW_THINKING=true
EFFORT=high
DELAY=1
DEBUG_REQUESTS=false

# Parallel agents — how many LLM agents work simultaneously (1-4)
# x1 = default single agent, x2/x3/x4 = parallel agents on different tasks
PARALLEL_AGENTS=1

# Virtual display — run browser on invisible Xvfb display (requires: apt install xvfb)
# Browser works normally but user doesn't see the window
VIRTUAL_DISPLAY=true

TG_BOT_TOKEN=
TG_USER_ID=

DATABASE_URL=
# DATABASE_URL=postgresql://user:pass@localhost:5432/mydb
# DATABASE_URL=mysql://user:pass@localhost:3306/mydb
# DATABASE_URL=sqlite:///data.db
# DATABASE_URL=mongodb://user:pass@localhost:27017/mydb
# DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/mydb

REFERENCE_SITES=[]
# REFERENCE_SITES=["https://example1.com", "https://example2.com", "https://example3.com"]

MCP_SERVERS_CONFIG=./mcp_servers.json
SKILLS_DIR=./skills
